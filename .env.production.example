# 운영 빌드용 (.env.production) — 실제 파일명을 `.env.production` 으로 바꿔서 사용.
# `.env.production` 은 gitignore 되어 있다. 이 example 파일만 tracked.
#
# 비밀이 아닌 값만 들어간다. 토스 디크립션 키 / JWT 시크릿 등은 절대 여기 두지 말고
# `wrangler secret put` 으로만 등록한다.
#
# 빌드 가드: `npm run build:submit` / `npm run build:ait` 는 `scripts/check-build-env.mjs`
# 가 먼저 실행되어 아래 값이 비어 있으면 중단한다:
#   - VITE_APPS_IN_TOSS_PROXY_URL (Worker URL)  — submit / ait 둘 다 필요
# brand icon URL 은 granite.config.ts 에 콘솔 등록 CDN URL 이 박혀 있으므로
# override 가 필요할 때만 APPS_IN_TOSS_BRAND_ICON_URL 을 지정한다.

VITE_MOCK_AUTH=false
VITE_USE_MOCK_LOGIN=false
VITE_TOSS_AUTH_MOCK=false
VITE_TOSS_AD_MOCK=false

# Cloudflare Worker (carrot-carrot-api) URL — `wrangler deploy` 출력값.
VITE_APPS_IN_TOSS_PROXY_URL=https://carrot-carrot-api.bunniesfarm.workers.dev

# Apps in Toss 콘솔에 등록된 브랜드 아이콘 URL (granite.config.ts 의 기본값과 동일).
# 비워두면 granite.config.ts 가 박아둔 콘솔 등록 CDN URL 을 그대로 사용한다.
# 콘솔에서 아이콘을 다시 업로드해 URL 이 바뀌었을 때만 새 URL 로 채운다.
APPS_IN_TOSS_BRAND_ICON_URL=https://static.toss.im/appsintoss/9399/e8354053-e837-4e0e-ad25-8a0834f06620.png

# OG / share preview 용 절대 URL. 콘솔 배포 URL 로 박는다.
# 비우면 vite.config.ts 의 기본값 (https://apps-in-toss.com/web/carrot-carrot) 사용.
PUBLIC_APP_URL=https://apps-in-toss.com/web/carrot-carrot
