# 버니타임 환경변수 (Cloudflare Worker + D1 only)
# 모든 값은 더미. 실제 키는 .env.local / .env.production 또는 wrangler secret 에 저장.
# Vite 는 VITE_ prefix 만 클라이언트로 노출.

# --- 클라이언트 (VITE_*) ---

# 일반 브라우저 / 로컬 / 비 WebView 환경에서는 mock 강제 (true 권장).
# false 로 두면 토스 SDK 호출을 시도하되, SDK 가 없으면 자동으로 게스트 폴백.
VITE_MOCK_AUTH=true
# 구버전 호환 — 새 코드는 VITE_MOCK_AUTH 우선. 같이 두어도 무방.
VITE_USE_MOCK_LOGIN=true

# Cloudflare Worker URL (carrot-carrot-api).
# `wrangler deploy` 후 출력되는 *.workers.dev URL 또는 커스텀 도메인.
# 비우면 클라이언트는 오프라인/mock 모드로 동작.
VITE_APPS_IN_TOSS_PROXY_URL=

# 토스 미니앱 — 클라이언트 ID 만 노출.
VITE_TOSS_CLIENT_ID=

# Apps in Toss 보상형 광고 그룹 ID — '백색소음 사운드 잠금해제 보상' (보상: 백색소음 사운드 1).
#
# 콘솔에 등록된 공식 그룹 ID 는 코드의 기본값으로 박혀 있어 (`ait.v2.live.146b65d064c2402e`)
# 이 변수를 비워둬도 운영 환경(토스 미니앱)에서는 자동으로 공식 그룹이 사용된다.
# 그룹 교체/롤백 시에만 다른 ID 로 덮어쓰면 된다.
# 외부 브라우저 / SDK 미지원 환경에서는 simulation 으로 fallback.
#
# 연동 네트워크: Pangle, AppLovin, Meta Audience Network, WF_15.08, WF_3.23,
# WF_6.46, WF_4.31, WF_21.54, WF_10.77, AdMob Network, Mintegral.
VITE_TOSS_AD_GROUP_ID=
# 구버전 호환 별칭 — VITE_TOSS_AD_GROUP_ID 미설정 시 fallback 으로 사용.
VITE_TOSS_AD_UNIT_ID=

# 보상형 광고 mock 강제. Perplexity preview / 외부 브라우저에서 true 권장.
# 운영(토스 미니앱) 에서는 미설정 또는 'false'.
VITE_TOSS_AD_MOCK=true

# Round 18 (PR-135) — 추가 광고 형식 ID. 현재 코드에는 wire 되지 않음
# (보상형만 활성). 콘솔 등록 시점에 메모만 해둠. Round 19+ 에서 wire 예정:
#   - 전면형 (interstitial): 결정적 순간 (ex: 5세션 완료 후) 노출
#   - 배너형 (banner):       타이머 끝 + 도감 페이지 하단 등 inline
VITE_TOSS_AD_INTERSTITIAL_ID=
VITE_TOSS_AD_BANNER_ID=


# --- Cloudflare Worker (`cloudflare/workers/carrot-carrot-api/wrangler.toml`) ---
# 비밀이 아닌 값은 wrangler.toml [vars] 에 직접 박혀있다.
#   APPS_IN_TOSS_APP_NAME = "carrot-carrot"
#   APPS_IN_TOSS_API_BASE = "https://apps-in-toss-api.toss.im"
#   APPS_IN_TOSS_DECRYPTION_AAD = "TOSS"
#   ALLOW_MOCK_LOGIN = "false"
#
# 시크릿은 `wrangler secret put` 으로 등록한다 (절대 .env 에 저장 금지).
#   wrangler secret put APPS_IN_TOSS_DECRYPTION_KEY  # base64 32B AES 키
#   wrangler secret put JWT_SECRET                   # openssl rand -hex 32
#
# mTLS 인증서는 `wrangler mtls-certificate upload` 로 업로드 후 certificate_id 를
# wrangler.toml 의 [[mtls_certificates]] 섹션에 박는다. PEM 텍스트는 .secrets/ 에만 두고
# 절대 커밋하지 않는다.

# --- Granite (Apps in Toss 콘솔 자산) ---
# 콘솔 등록용 브랜드 아이콘 URL. granite.config.ts 가 빌드 시 참조.
APPS_IN_TOSS_BRAND_ICON_URL=

# --- OG / 소셜 share preview ---
# 소셜 크롤러는 base path 를 모르므로 og:image / og:url 은 절대 https URL.
# vite.config.ts 가 빌드 시 index.html 의 %OG_PUBLIC_URL% / %OG_IMAGE_URL%
# 을 이 값으로 치환한다. 비우면 기본값 (https://apps-in-toss.com/web/carrot-carrot)
# 이 사용된다. PUBLIC_APP_URL / VITE_PUBLIC_APP_URL 둘 다 인식.
PUBLIC_APP_URL=
