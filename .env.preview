# Preview build (`npm run build:preview`) — no Toss SDK, no Worker.
# Produces dist-preview/ that runs in any plain browser. Mock auth bypasses
# the Apps-in-Toss login gate; farm/timer/state all run on local in-memory
# state. Do NOT use for submission to Toss.
VITE_MOCK_AUTH=true
VITE_USE_MOCK_LOGIN=true
VITE_TOSS_AUTH_MOCK=true
VITE_TOSS_AD_MOCK=true
VITE_APPS_IN_TOSS_PROXY_URL=
