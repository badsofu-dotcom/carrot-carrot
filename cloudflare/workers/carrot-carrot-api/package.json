{
  "name": "carrot-carrot-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:dry-run": "wrangler deploy --dry-run",
    "typecheck": "tsc --noEmit",
    "migrations:apply:remote": "wrangler d1 migrations apply carrot-carrot-db --remote",
    "migrations:apply:local": "wrangler d1 migrations apply carrot-carrot-db --local"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250410.0",
    "typescript": "^5.7.3",
    "wrangler": "^4.10.0"
  }
}
